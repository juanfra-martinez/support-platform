# ----- Application -----
NODE_ENV=development
PORT=3000
WORKER_PORT=3001
API_GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:4200

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql://support:support@localhost:5432/support_platform?schema=public

# ----- JWT -----
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d

# ----- Security -----
BCRYPT_SALT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ----- RabbitMQ -----
RABBITMQ_URI=amqp://support:support@localhost:5672
RABBITMQ_EXCHANGE=support.events

# ----- Outbox relay (producer) -----
OUTBOX_POLL_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5

# ----- Consumers (worker) -----
# Bounded in-queue retries before a message is dead-lettered to the DLX/dlq.
CONSUMER_MAX_RETRIES=3
