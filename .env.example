# ============================================================================
# Full-stack deployment configuration. Copy to `.env` and adjust before
# running `docker compose up --build`. docker-compose reads this file
# automatically.
# ============================================================================

# ----- PostgreSQL -----
POSTGRES_USER=support
POSTGRES_PASSWORD=support
POSTGRES_DB=support_platform

# ----- RabbitMQ -----
RABBITMQ_USER=support
RABBITMQ_PASSWORD=support

# ----- JWT (CHANGE THESE; each must be at least 16 chars) -----
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d

# ----- Security -----
BCRYPT_SALT_ROUNDS=12

# ----- Messaging (consumers) -----
CONSUMER_MAX_RETRIES=3

# ----- CORS: the public origin the browser loads the SPA from -----
CORS_ORIGIN=http://localhost:8080

# ----- Host port mappings -----
FRONTEND_PORT=8080
BACKEND_PORT=3000
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
